---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---
<section class="contact" id="contact">
  <div class="container">
    <h2 class="section-title">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>
    <form class="contact-form">
      <div class="form-row">
        <input type="text" placeholder="Your Name" required />
        <input type="email" placeholder="Your Email" required />
      </div>
      <select required>
        <option value="">Select a Plan</option>
        <option value="starter">Starter - $49/month</option>
        <option value="professional">Professional - $99/month</option>
        <option value="elite">Elite - $249/month</option>
      </select>
      <textarea placeholder="Tell us about your trading experience..." rows="4"></textarea>
      <button type="submit" class="btn btn-primary btn-large">Start Your Journey</button>
    </form>
  </div>
</section>
